{
  "name": "zeing",
  "version": "0.1.0",
  "private": true,
  "description": "A personal website for Zeing",
  "author": "Zeing",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20.x",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "deploy": "next build && cp CNAME public && gh-pages -b .next -d public",
    "ph-clean": "gh-pages-clean",
    "format": "oxfmt .",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "classnames": "^2.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next": "^16.2.4",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.10",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-video-cover": "^1.2.2",
    "tailwindcss": "^4.2.4",
    "typed.js": "^3.0.0",
    "typescript": "^5.8.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "bun run lint && bun run format"
    }
  },
  "lint-staged": {
    "*.+(ts|tsx)": "oxlint --fix",
    "*.+(ts|tsx|json|css|md)": "oxfmt --write"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
